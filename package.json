{
  "name": "to-the-stars",
  "private": true,
  "version": "1.0.0",
  "main": "index.js",
  "scripts": {
    "docs-setup": "esno .vuepress/init.ts",
    "docs-dev": "vuepress dev",
    "docs-build": "pnpm docs-setup && vuepress build && rimraf .vuepress/dist/books/",
    "docs-deploy": "pnpm docs-build && liuli-cli deploy",
    "build": "esno src/main.ts"
  },
  "deploy": {
    "type": "gh-pages",
    "dist": ".vuepress/dist"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@liuli-util/async": "^3.4.0",
    "@liuli-util/cli": "^3.21.0",
    "@liuli-util/mdbook": "^0.1.1",
    "@liuli-util/prettier-standard-config": "^0.3.0",
    "@types/fs-extra": "^9.0.13",
    "@types/jest": "^28.1.6",
    "@types/node": "^18.6.2",
    "@vue/component-compiler-utils": "^3.3.0",
    "@vuepress/client": "^2.0.0-beta.49",
    "@vuepress/plugin-google-analytics": "^1.9.7",
    "@vuepress/shared-utils": "^1.9.7",
    "@vuepress/theme-default": "^2.0.0-beta.49",
    "chinese-numbering": "^1.0.0",
    "esno": "^0.16.3",
    "fs-extra": "^10.1.0",
    "jest": "^28.1.3",
    "joplin-api": "^0.4.2",
    "rimraf": "^3.0.2",
    "ts-jest": "^28.0.7",
    "typescript": "^4.7.4",
    "vue": "^3.2.37",
    "vuepress-plugin-sitemap2": "^2.0.0-beta.24",
    "vuepress-vite": "^2.0.0-beta.45"
  },
  "jest": {
    "preset": "ts-jest",
    "testMatch": [
      "<rootDir>/src/**/__tests__/*.test.ts"
    ]
  },
  "pnpm": {
    "peerDependencyRules": {
      "allowedVersions": {
        "@vuepress/client": "2.0.0-beta.49"
      }
    }
  }
}
